<odoo>
  <template id="report_prescription_document"><t t-call="web.html_container"><t t-foreach="docs" t-as="o"><t t-call="web.external_layout"><div class="page"><h2>Prescription: <span t-field="o.name"/></h2><p><strong>Patient:</strong> <span t-field="o.patient_id.name"/> | <strong>DOB:</strong> <span t-field="o.patient_id.date_of_birth"/></p><p><strong>Doctor:</strong> <span t-field="o.doctor_id.name"/> | <strong>Date:</strong> <span t-field="o.prescription_date"/></p><p><strong>Diagnosis/Notes:</strong> <span t-field="o.diagnosis_notes"/></p><table class="table table-sm"><thead><tr><th>Medication</th><th>Strength</th><th>Form</th><th>Qty</th><th>Remaining</th><th>Instructions</th></tr></thead><tbody><tr t-foreach="o.line_ids" t-as="l"><td><span t-field="l.product_id.display_name"/></td><td><span t-field="l.strength"/></td><td><span t-field="l.dosage_form"/></td><td><span t-field="l.qty_prescribed"/></td><td><span t-field="l.qty_remaining"/></td><td><span t-field="l.instructions"/></td></tr></tbody></table></div></t></t></t></template>
  <template id="report_dispensing_log_document"><t t-call="web.html_container"><t t-foreach="docs" t-as="o"><t t-call="web.external_layout"><div class="page"><h2>Dispensing Log: <span t-field="o.name"/></h2><p><strong>Prescription:</strong> <span t-field="o.prescription_id.name"/> | <strong>Date:</strong> <span t-field="o.dispense_date"/></p><p><strong>Patient:</strong> <span t-field="o.patient_id.name"/> | <strong>Pharmacist:</strong> <span t-field="o.pharmacist_initials"/></p><table class="table table-sm"><thead><tr><th>Medication</th><th>Qty Supplied</th><th>Remaining</th><th>Batch/Lot</th><th>Expiry</th></tr></thead><tbody><tr t-foreach="o.line_ids" t-as="l"><td><span t-field="l.product_id.display_name"/></td><td><span t-field="l.qty_dispensed"/></td><td><span t-field="l.qty_remaining_after"/></td><td><span t-field="l.lot_id.name"/></td><td><span t-field="l.expiration_date"/></td></tr></tbody></table><p><strong>Notes:</strong> <span t-field="o.notes"/></p></div></t></t></t></template>
</odoo>
