<odoo>
  <record id="module_category_pharmacy" model="ir.module.category"><field name="name">Pharmacy</field><field name="sequence">25</field></record>
  <record id="group_pharmacy_user" model="res.groups"><field name="name">Pharmacy User</field><field name="category_id" ref="module_category_pharmacy"/></record>
  <record id="group_pharmacy_pharmacist" model="res.groups"><field name="name">Pharmacist</field><field name="category_id" ref="module_category_pharmacy"/><field name="implied_ids" eval="[(4, ref('group_pharmacy_user'))]"/></record>
  <record id="group_pharmacy_manager" model="res.groups"><field name="name">Pharmacy Manager</field><field name="category_id" ref="module_category_pharmacy"/><field name="implied_ids" eval="[(4, ref('group_pharmacy_pharmacist'))]"/></record>
</odoo>
