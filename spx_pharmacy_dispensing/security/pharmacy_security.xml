<odoo>
  <!-- Odoo 19 compatibility: res.groups no longer accepts category_id in this environment. -->
  <record id="group_pharmacy_user" model="res.groups">
    <field name="name">Pharmacy User</field>
  </record>

  <record id="group_pharmacy_pharmacist" model="res.groups">
    <field name="name">Pharmacist</field>
    <field name="implied_ids" eval="[(4, ref('group_pharmacy_user'))]"/>
  </record>

  <record id="group_pharmacy_manager" model="res.groups">
    <field name="name">Pharmacy Manager</field>
    <field name="implied_ids" eval="[(4, ref('group_pharmacy_pharmacist'))]"/>
  </record>
</odoo>
