<odoo>
  <record id="view_pharmacy_alert_tree" model="ir.ui.view"><field name="name">pharmacy.safety.alert.tree</field><field name="model">pharmacy.safety.alert</field><field name="arch" type="xml"><list decoration-danger="severity in ('high','critical')"><field name="create_date"/><field name="prescription_id"/><field name="patient_id"/><field name="alert_type"/><field name="severity"/><field name="message"/><field name="state"/></list></field></record>
  <record id="view_pharmacy_alert_form" model="ir.ui.view"><field name="name">pharmacy.safety.alert.form</field><field name="model">pharmacy.safety.alert</field><field name="arch" type="xml"><form><header><button name="%(action_pharmacy_alert_override_wizard)d" string="Override" type="action" groups="spx_pharmacy_dispensing.group_pharmacy_manager" context="{'default_alert_id': active_id}"/><field name="state" widget="statusbar"/></header><sheet><group><field name="prescription_id"/><field name="patient_id"/><field name="alert_type"/><field name="severity"/><field name="message"/><field name="override_reason"/><field name="override_user_id"/><field name="override_date"/></group></sheet><chatter/></form></field></record>
  <record id="action_pharmacy_alert" model="ir.actions.act_window"><field name="name">Safety Alerts</field><field name="res_model">pharmacy.safety.alert</field><field name="view_mode">list,form</field></record>
</odoo>
