<odoo>
  <record id="view_pharmacy_dispensing_log_tree" model="ir.ui.view"><field name="name">pharmacy.dispensing.log.tree</field><field name="model">pharmacy.dispensing.log</field><field name="arch" type="xml"><list decoration-muted="state == 'void'"><field name="name"/><field name="dispense_date"/><field name="prescription_id"/><field name="patient_id"/><field name="pharmacist_initials"/><field name="register_type"/><field name="state"/></list></field></record>
  <record id="view_pharmacy_dispensing_log_form" model="ir.ui.view"><field name="name">pharmacy.dispensing.log.form</field><field name="model">pharmacy.dispensing.log</field><field name="arch" type="xml"><form><header><button name="action_void" string="Void" type="object" groups="spx_pharmacy_dispensing.group_pharmacy_manager"/><field name="state" widget="statusbar"/></header><sheet><div class="oe_title"><h1><field name="name" readonly="1"/></h1></div><group><group><field name="prescription_id" readonly="1"/><field name="patient_id" readonly="1"/><field name="doctor_id" readonly="1"/></group><group><field name="dispense_date" readonly="1"/><field name="pharmacist_id" readonly="1"/><field name="pharmacist_initials" readonly="1"/><field name="register_type" readonly="1"/></group></group><field name="line_ids" readonly="1"><list><field name="product_id"/><field name="qty_prescribed"/><field name="qty_dispensed"/><field name="qty_remaining_after"/><field name="lot_id"/><field name="expiration_date"/><field name="is_refill"/><field name="register_type"/></list></field><group><field name="notes"/><field name="void_reason" readonly="1"/></group></sheet><chatter/></form></field></record>
  <record id="action_pharmacy_dispensing_log" model="ir.actions.act_window"><field name="name">Dispensing Logs</field><field name="res_model">pharmacy.dispensing.log</field><field name="view_mode">list,form</field></record>
</odoo>
