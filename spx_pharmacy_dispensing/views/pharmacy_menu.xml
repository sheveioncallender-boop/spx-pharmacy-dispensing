<odoo>
  <!-- V3.0.5: Main navigation intentionally has no menu group restriction so the Pharmacy app is visible after install/upgrade. Record access is still controlled by ir.model.access.csv. -->
  <menuitem id="menu_pharmacy_root" name="Pharmacy" sequence="10" web_icon="spx_pharmacy_dispensing,static/description/icon.png"/>
  <menuitem id="menu_pharmacy_dashboard" name="Dashboard" parent="menu_pharmacy_root" action="action_pharmacy_dashboard" sequence="1"/>
  <menuitem id="menu_pharmacy_patients" name="Patients" parent="menu_pharmacy_root" action="action_pharmacy_patient" sequence="5"/>
  <menuitem id="menu_pharmacy_prescriptions" name="Prescriptions" parent="menu_pharmacy_root" action="action_pharmacy_prescription" sequence="10"/>
  <menuitem id="menu_pharmacy_dispensing" name="Dispensing" parent="menu_pharmacy_root" action="action_pharmacy_dispensing_log" sequence="15"/>
  <menuitem id="menu_pharmacy_registers" name="Drug Registers" parent="menu_pharmacy_root" sequence="20"/>
  <menuitem id="menu_pharmacy_antibiotic_register" name="Antibiotics" parent="menu_pharmacy_registers" action="action_pharmacy_register_antibiotic" sequence="1"/>
  <menuitem id="menu_pharmacy_controlled_register" name="Controlled Drugs" parent="menu_pharmacy_registers" action="action_pharmacy_register_controlled" sequence="2"/>
  <menuitem id="menu_pharmacy_narcotic_register" name="Narcotics" parent="menu_pharmacy_registers" action="action_pharmacy_register_narcotic" sequence="3"/>
  <menuitem id="menu_pharmacy_reports" name="Reports" parent="menu_pharmacy_root" sequence="30"/>
  <menuitem id="menu_pharmacy_alerts" name="Safety Alerts" parent="menu_pharmacy_reports" action="action_pharmacy_alert" sequence="1"/>
  <menuitem id="menu_pharmacy_audit" name="Audit Trail" parent="menu_pharmacy_reports" action="action_pharmacy_audit" sequence="2"/>
  <menuitem id="menu_pharmacy_config" name="Configuration" parent="menu_pharmacy_root" sequence="50"/>
  <menuitem id="menu_pharmacy_allergens" name="Allergies" parent="menu_pharmacy_config" action="action_pharmacy_allergen" sequence="1"/>
  <menuitem id="menu_pharmacy_drug_classes" name="Drug Classes" parent="menu_pharmacy_config" action="action_pharmacy_drug_class" sequence="2"/>
  <menuitem id="menu_pharmacy_interactions" name="Drug Interactions" parent="menu_pharmacy_config" action="action_pharmacy_interaction" sequence="3"/>

  <!-- Explicitly clear old groups left over from previous installs/updates. -->
  <record id="menu_pharmacy_root" model="ir.ui.menu"><field name="groups_id" eval="[(5, 0, 0)]"/></record>
  <record id="menu_pharmacy_dashboard" model="ir.ui.menu"><field name="groups_id" eval="[(5, 0, 0)]"/></record>
  <record id="menu_pharmacy_patients" model="ir.ui.menu"><field name="groups_id" eval="[(5, 0, 0)]"/></record>
  <record id="menu_pharmacy_prescriptions" model="ir.ui.menu"><field name="groups_id" eval="[(5, 0, 0)]"/></record>
  <record id="menu_pharmacy_dispensing" model="ir.ui.menu"><field name="groups_id" eval="[(5, 0, 0)]"/></record>
  <record id="menu_pharmacy_registers" model="ir.ui.menu"><field name="groups_id" eval="[(5, 0, 0)]"/></record>
  <record id="menu_pharmacy_reports" model="ir.ui.menu"><field name="groups_id" eval="[(5, 0, 0)]"/></record>
  <record id="menu_pharmacy_config" model="ir.ui.menu"><field name="groups_id" eval="[(5, 0, 0)]"/></record>
</odoo>
