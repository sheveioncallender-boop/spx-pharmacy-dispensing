<odoo>
  <record id="view_pharmacy_patient_tree" model="ir.ui.view"><field name="name">pharmacy.patient.tree</field><field name="model">pharmacy.patient</field><field name="arch" type="xml"><tree><field name="code"/><field name="name"/><field name="date_of_birth"/><field name="age"/><field name="phone"/><field name="primary_doctor_id"/><field name="active"/></tree></field></record>
  <record id="view_pharmacy_patient_form" model="ir.ui.view"><field name="name">pharmacy.patient.form</field><field name="model">pharmacy.patient</field><field name="arch" type="xml"><form string="Patient"><header><button name="action_view_prescriptions" string="Prescriptions" type="object" class="oe_stat_button"/><button name="action_view_dispensing" string="Dispensing History" type="object" class="oe_stat_button"/></header><sheet><div class="oe_title"><h1><field name="name" placeholder="Patient Name"/></h1><field name="code" readonly="1"/></div><group><group><field name="date_of_birth"/><field name="age" readonly="1"/><field name="gender"/><field name="blood_group"/></group><group><field name="phone"/><field name="email"/><field name="partner_id"/><field name="active"/></group></group><group><field name="primary_doctor_id"/><field name="allergy_ids" widget="many2many_tags"/><field name="address"/><field name="medical_notes"/></group><notebook><page string="Prescriptions"><field name="prescription_ids" readonly="1"/></page><page string="Dispensing History"><field name="dispensing_log_ids" readonly="1"/></page></notebook></sheet><chatter/></form></field></record>
  <record id="action_pharmacy_patient" model="ir.actions.act_window"><field name="name">Patients</field><field name="res_model">pharmacy.patient</field><field name="view_mode">tree,form</field></record>
</odoo>
