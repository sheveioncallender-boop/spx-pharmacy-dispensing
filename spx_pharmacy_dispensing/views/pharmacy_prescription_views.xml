<odoo>
  <record id="view_pharmacy_prescription_tree" model="ir.ui.view"><field name="name">pharmacy.prescription.tree</field><field name="model">pharmacy.prescription</field><field name="arch" type="xml"><list decoration-danger="has_blocking_alert"><field name="name"/><field name="prescription_date"/><field name="patient_id"/><field name="doctor_id"/><field name="state"/><field name="amount_total"/></list></field></record>
  <record id="view_pharmacy_prescription_form" model="ir.ui.view"><field name="name">pharmacy.prescription.form</field><field name="model">pharmacy.prescription</field><field name="arch" type="xml"><form string="Prescription"><header><button name="action_check_safety" string="Check Safety" type="object" class="btn-secondary"/><button name="action_open_dispense_wizard" string="Dispense" type="object" class="btn-primary"/><button name="action_create_sale_order" string="Create Sale Order" type="object" class="btn-secondary"/><field name="state" widget="statusbar" statusbar_visible="draft,checked,partially_dispensed,dispensed"/></header><sheet><div class="oe_title"><h1><field name="name" readonly="1"/></h1></div><group><group><field name="patient_id"/><field name="doctor_id"/><field name="prescription_date"/><field name="diagnosis_notes"/></group><group><field name="sale_order_id" readonly="1"/><field name="pos_order_id" readonly="1"/><field name="alert_count" readonly="1"/><field name="dispensing_count" readonly="1"/><field name="has_blocking_alert" readonly="1"/><field name="prescription_file_count" readonly="1"/></group></group><notebook><page string="Medication Lines"><field name="line_ids"><list editable="bottom"><field name="product_id"/><field name="strength"/><field name="dosage_form"/><field name="qty_prescribed"/><field name="qty_dispensed"/><field name="qty_remaining"/><field name="instructions"/><field name="repeat_allowed"/><field name="refill_total"/><field name="refill_used"/><field name="price_unit"/><field name="price_subtotal"/></list></field></page><page string="Safety Alerts"><field name="alert_ids" readonly="1"><list decoration-danger="severity in ('high','critical')"><field name="alert_type"/><field name="severity"/><field name="message"/><field name="state"/></list></field></page><page string="Dispensing History"><field name="dispensing_log_ids" readonly="1"/></page><page string="Prescription Files"><field name="prescription_file_ids" readonly="1"><list><field name="name"/><field name="mimetype"/><field name="create_date"/><field name="create_uid"/></list></field></page></notebook></sheet><chatter/></form></field></record>
  <record id="action_pharmacy_prescription" model="ir.actions.act_window"><field name="name">Prescriptions</field><field name="res_model">pharmacy.prescription</field><field name="view_mode">list,form</field></record>
</odoo>
