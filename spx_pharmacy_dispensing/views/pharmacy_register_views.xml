<odoo>
  <record id="view_pharmacy_register_tree" model="ir.ui.view"><field name="name">pharmacy.drug.register.tree</field><field name="model">pharmacy.drug.register</field><field name="arch" type="xml"><tree><field name="dispense_date"/><field name="register_type"/><field name="prescription_id"/><field name="patient_id"/><field name="doctor_id"/><field name="product_id"/><field name="qty_supplied"/><field name="qty_remaining"/><field name="lot_id"/><field name="pharmacist_initials"/></tree></field></record>
  <record id="view_pharmacy_register_form" model="ir.ui.view"><field name="name">pharmacy.drug.register.form</field><field name="model">pharmacy.drug.register</field><field name="arch" type="xml"><form><sheet><group><field name="register_type"/><field name="dispense_date"/><field name="prescription_id"/><field name="dispensing_log_id"/><field name="patient_id"/><field name="doctor_id"/><field name="product_id"/><field name="qty_supplied"/><field name="qty_remaining"/><field name="lot_id"/><field name="pharmacist_initials"/></group></sheet><chatter/></form></field></record>
  <record id="action_pharmacy_register_antibiotic" model="ir.actions.act_window"><field name="name">Antibiotic Register</field><field name="res_model">pharmacy.drug.register</field><field name="view_mode">tree,form</field><field name="domain">[('register_type','=','antibiotic')]</field></record>
  <record id="action_pharmacy_register_controlled" model="ir.actions.act_window"><field name="name">Controlled Drug Register</field><field name="res_model">pharmacy.drug.register</field><field name="view_mode">tree,form</field><field name="domain">[('register_type','=','controlled')]</field></record>
  <record id="action_pharmacy_register_narcotic" model="ir.actions.act_window"><field name="name">Narcotic Register</field><field name="res_model">pharmacy.drug.register</field><field name="view_mode">tree,form</field><field name="domain">[('register_type','=','narcotic')]</field></record>
</odoo>
