<odoo>
  <record id="view_sale_order_pharmacy_form" model="ir.ui.view">
    <field name="name">sale.order.pharmacy.form</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='partner_id']" position="after">
        <field name="pharmacy_prescription_id"/>
      </xpath>
    </field>
  </record>

  <record id="view_pos_order_pharmacy_form" model="ir.ui.view">
    <field name="name">pos.order.pharmacy.form</field>
    <field name="model">pos.order</field>
    <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='partner_id']" position="after">
        <field name="pharmacy_prescription_id"/>
        <field name="pharmacy_patient_id" readonly="1"/>
        <field name="pharmacy_prescription_required" readonly="1"/>
      </xpath>
      <xpath expr="//sheet" position="inside">
        <group string="Pharmacy Prescription Linkage">
          <field name="pharmacy_pharmacist_initials"/>
          <field name="pharmacy_prescription_notes"/>
          <field name="pharmacy_prescription_attachment" filename="pharmacy_prescription_attachment_name"/>
          <field name="pharmacy_prescription_attachment_name" invisible="1"/>
          <button name="action_create_pharmacy_prescription" type="object" string="Create / Open Prescription" class="btn-primary"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
